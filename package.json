{
  "name": "junipra",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "deploy:firebase": "npx -y firebase-tools@latest deploy --project junipra-da9b4 --only hosting,firestore:rules,firestore:indexes",
    "preview:firebase": "npx -y firebase-tools@latest hosting:channel:deploy preview --project junipra-da9b4",
    "emulate:firebase": "npx -y firebase-tools@latest emulators:start --project junipra-da9b4 --only hosting,firestore"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@vueuse/core": "^14.2.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "firebase": "^12.11.0",
    "lucide-vue-next": "^1.0.0",
    "reka-ui": "^2.9.3",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.2",
    "vue": "^3.5.30",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@types/node": "^24.12.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/tsconfig": "^0.9.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "~5.9.3",
    "vite": "^8.0.1",
    "vite-tsconfig-paths": "^6.1.1",
    "vue-tsc": "^3.2.5"
  }
}
